{% extends 'base.html.twig' %}

{% block title %}Tomorrow's Bets{% endblock %}

{% block stylesheets %}
<style>
    *, *::before, *::after { box-sizing: border-box; }

    body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        max-width: 960px;
        margin: 2rem auto;
        padding: 0 1.25rem;
        background: #f8fafc;
        color: #1e293b;
    }

    a { color: #3b82f6; text-decoration: none; font-size: 0.85rem; }
    a:hover { text-decoration: underline; }
    .nav-link { display: inline-block; margin-bottom: 1.5rem; }

    h1 {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
        color: #0f172a;
    }

    /* ── Card ── */
    .card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-left: 4px solid transparent;
        border-radius: 10px;
        margin-bottom: 0.75rem;
        box-shadow: 0 1px 3px rgba(0,0,0,.06);
        transition: box-shadow .15s;
        overflow: hidden;
    }
    .card:hover { box-shadow: 0 4px 12px rgba(0,0,0,.1); }
    .card.highlighted { border-left-color: #f59e0b; }

    /* ── Card header (always visible, clickable) ── */
    .card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.25rem;
        cursor: pointer;
        user-select: none;
        gap: 1rem;
    }
    .card-header::-webkit-details-marker { display: none; }

    .header-left { display: flex; flex-direction: column; gap: 0.2rem; min-width: 0; }

    .match-title {
        font-size: 1.05rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
    }
    .vs { color: #94a3b8; font-weight: 400; font-size: 0.9rem; }
    .tracked-name { font-weight: 800; color: #1d4ed8; }

    .match-meta {
        font-size: 0.82rem;
        color: #64748b;
    }

    .header-badges {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        flex-shrink: 0;
    }

    /* ── Badges ── */
    .pill {
        display: inline-block;
        padding: 0.2rem 0.55rem;
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: .02em;
        white-space: nowrap;
    }
    .pill-tomorrow  { background: #fef3c7; color: #92400e; border: 1px solid #f59e0b; }
    .pill-home      { background: #dbeafe; color: #1d4ed8; }
    .pill-away      { background: #ede9fe; color: #6d28d9; }
    .pill-no-fix    { background: #f1f5f9; color: #94a3b8; }
    .pill-over25    { background: #d1fae5; color: #065f46; border: 1px solid #6ee7b7; }
    .pill-over15    { background: #bbf7d0; color: #14532d; border: 1px solid #4ade80; }
    .pill-over35    { background: #a7f3d0; color: #064e3b; border: 1px solid #34d399; }
    .pill-under25   { background: #fee2e2; color: #991b1b; border: 1px solid #fca5a5; }
    .pill-home-win  { background: #fef9c3; color: #854d0e; border: 1px solid #fbbf24; }
    .pill-away-win  { background: #ede9fe; color: #4c1d95; border: 1px solid #a78bfa; }
    .pill-dc        { background: #fef3c7; color: #78350f; border: 1px solid #fcd34d; }
    .pill-ht        { background: #e0f2fe; color: #0c4a6e; border: 1px solid #7dd3fc; }
    .pill-wbh       { background: #fce7f3; color: #831843; border: 1px solid #f9a8d4; }

    /* ── Form badges ── */
    .badge {
        display: inline-block;
        width: 1.6rem;
        height: 1.6rem;
        line-height: 1.6rem;
        text-align: center;
        border-radius: 5px;
        font-size: 0.78rem;
        font-weight: 700;
        margin-right: 2px;
    }
    .badge-W { background: #d1fae5; color: #065f46; }
    .badge-D { background: #f1f5f9; color: #374151; }
    .badge-L { background: #fee2e2; color: #991b1b; }

    /* ── Card body ── */
    .card-body {
        padding: 0 1.25rem 1.25rem;
        border-top: 1px solid #f1f5f9;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.25rem 2rem;
    }

    .stat-column { display: flex; flex-direction: column; gap: 0.9rem; padding-top: 1rem; }

    .column-title {
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
        color: #94a3b8;
        margin-bottom: 0.1rem;
    }
    .column-title.tracked { color: #1d4ed8; }

    .stat-block { display: flex; flex-direction: column; gap: 0.25rem; }
    .stat-label { font-size: 0.78rem; color: #64748b; }
    .stat-value { display: flex; align-items: center; gap: 0.15rem; flex-wrap: wrap; }

    .goals-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        padding: 0.25rem 0.6rem;
        font-size: 0.85rem;
    }
    .goals-num { font-weight: 700; color: #0f172a; }
    .goals-den { color: #94a3b8; font-size: 0.78rem; }

    .no-data { color: #cbd5e1; font-style: italic; font-size: 0.82rem; }

    /* ── Divider between columns ── */
    .card-body .stat-column:first-child {
        border-right: 1px solid #f1f5f9;
        padding-right: 1rem;
    }
    .card-body .stat-column:last-child {
        padding-left: 0.25rem;
    }

    /* ── Responsive ── */
    @media (max-width: 600px) {
        .card-body { grid-template-columns: 1fr; }
        .card-body .stat-column:first-child { border-right: none; border-bottom: 1px solid #f1f5f9; padding-right: 0; padding-bottom: 1rem; }
        .card-body .stat-column:last-child { padding-left: 0; }
    }
</style>
{% endblock %}

{% block body %}
<h1>Tomorrow's Bets</h1>
<a href="{{ path('bets_history') }}" class="nav-link">Ver historial de apuestas →</a>

{% if bets is empty %}
    <p class="no-data">No tracked teams found.</p>
{% else %}
    {% for bet in bets %}
    <details class="card{% if bet.highlightedTomorrow %} highlighted{% endif %}">
        <summary class="card-header">
            <div class="header-left">
                <div class="match-title">
                    {% if bet.nextFixtureDate %}
                        <span class="{{ bet.homeTeamName in bet.trackedTeamNames ? 'tracked-name' : '' }}">{{ bet.homeTeamName }}</span>
                        <span class="vs">vs</span>
                        <span class="{{ bet.awayTeamName in bet.trackedTeamNames ? 'tracked-name' : '' }}">{{ bet.awayTeamName }}</span>
                    {% else %}
                        <span class="tracked-name">{{ bet.homeTeamName }}</span>
                    {% endif %}
                </div>
                <div class="match-meta">
                    {% if bet.nextFixtureDate %}
                        {{ bet.nextFixtureDate }}
                    {% else %}
                        No fixture scheduled
                    {% endif %}
                </div>
            </div>
            <div class="header-badges">
                {% if bet.highlightedTomorrow %}
                    <span class="pill pill-tomorrow">TOMORROW</span>
                {% endif %}
                {% if not bet.nextFixtureDate %}
                    <span class="pill pill-no-fix">—</span>
                {% endif %}
                {% if 'over_1_5' in bet.activeBetTypes %}
                    <span class="pill pill-over15">OV 1.5</span>
                {% endif %}
                {% if 'over_2_5' in bet.activeBetTypes %}
                    <span class="pill pill-over25">OV 2.5</span>
                {% endif %}
                {% if 'over_3_5' in bet.activeBetTypes %}
                    <span class="pill pill-over35">OV 3.5</span>
                {% endif %}
                {% if 'under_2_5' in bet.activeBetTypes %}
                    <span class="pill pill-under25">UN 2.5</span>
                {% endif %}
                {% if 'home_win' in bet.activeBetTypes %}
                    <span class="pill pill-home-win">1</span>
                {% endif %}
                {% if 'away_win' in bet.activeBetTypes %}
                    <span class="pill pill-away-win">2</span>
                {% endif %}
                {% if 'double_chance' in bet.activeBetTypes %}
                    <span class="pill pill-dc">1X</span>
                {% endif %}
                {% if 'over_05_ht' in bet.activeBetTypes %}
                    <span class="pill pill-ht">OV 0.5 HT</span>
                {% endif %}
                {% if 'win_both_halves' in bet.activeBetTypes %}
                    <span class="pill pill-wbh">WBH</span>
                {% endif %}
            </div>
        </summary>

        <div class="card-body">

            {# ── Left column: home team ── #}
            <div class="stat-column">
                <div class="column-title{{ bet.homeTeamName in bet.trackedTeamNames ? ' tracked' : '' }}">{{ bet.homeTeamName }}</div>

                <div class="stat-block">
                    <div class="stat-label">Form — last 8</div>
                    <div class="stat-value">
                        {% if bet.homeFormLast8 %}
                            {% for char in bet.homeFormLast8|split('') %}
                                <span class="badge badge-{{ char }}">{{ char }}</span>
                            {% endfor %}
                        {% else %}
                            <span class="no-data">No data</span>
                        {% endif %}
                    </div>
                </div>

                <div class="stat-block">
                    <div class="stat-label">Form at home — last 5</div>
                    <div class="stat-value">
                        {% if bet.homeFormSituational %}
                            {% for char in bet.homeFormSituational|split('') %}
                                <span class="badge badge-{{ char }}">{{ char }}</span>
                            {% endfor %}
                        {% else %}
                            <span class="no-data">No data</span>
                        {% endif %}
                    </div>
                </div>

                {% if bet.homeMatchesPlayed > 0 %}
                <div class="stat-block">
                    <div class="stat-label">Goals at home</div>
                    <div class="stat-value">
                        <span class="goals-chip"><span class="goals-num">OV1.5: {{ bet.homeOver15 }}</span><span class="goals-den">/ {{ bet.homeMatchesPlayed }}</span></span>
                        <span class="goals-chip"><span class="goals-num">OV2.5: {{ bet.homeOver25 }}</span><span class="goals-den">/ {{ bet.homeMatchesPlayed }}</span></span>
                        <span class="goals-chip"><span class="goals-num">OV3.5: {{ bet.homeOver35 }}</span><span class="goals-den">/ {{ bet.homeMatchesPlayed }}</span></span>
                    </div>
                </div>
                {% endif %}
            </div>

            {# ── Right column: away team ── #}
            <div class="stat-column">
                <div class="column-title{{ bet.awayTeamName in bet.trackedTeamNames ? ' tracked' : '' }}">{{ bet.awayTeamName ?: 'Rival' }}</div>

                <div class="stat-block">
                    <div class="stat-label">Form away — last 5</div>
                    <div class="stat-value">
                        {% if bet.awayFormSituational %}
                            {% for char in bet.awayFormSituational|split('') %}
                                <span class="badge badge-{{ char }}">{{ char }}</span>
                            {% endfor %}
                        {% else %}
                            <span class="no-data">No data</span>
                        {% endif %}
                    </div>
                </div>

                {% if bet.awayMatchesPlayed > 0 %}
                <div class="stat-block">
                    <div class="stat-label">Goals away</div>
                    <div class="stat-value">
                        <span class="goals-chip"><span class="goals-num">OV1.5: {{ bet.awayOver15 }}</span><span class="goals-den">/ {{ bet.awayMatchesPlayed }}</span></span>
                        <span class="goals-chip"><span class="goals-num">OV2.5: {{ bet.awayOver25 }}</span><span class="goals-den">/ {{ bet.awayMatchesPlayed }}</span></span>
                        <span class="goals-chip"><span class="goals-num">OV3.5: {{ bet.awayOver35 }}</span><span class="goals-den">/ {{ bet.awayMatchesPlayed }}</span></span>
                    </div>
                </div>
                {% endif %}
            </div>

        </div>
    </details>
    {% endfor %}
{% endif %}
{% endblock %}
