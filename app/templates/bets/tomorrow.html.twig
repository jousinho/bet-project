{% extends 'base.html.twig' %}

{% block title %}Tomorrow's Bets{% endblock %}

{% block stylesheets %}
<style>
    *, *::before, *::after { box-sizing: border-box; }

    body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        max-width: 960px;
        margin: 2rem auto;
        padding: 0 1.25rem;
        background: #f8fafc;
        color: #1e293b;
    }

    h1 {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
        color: #0f172a;
    }

    /* ── Card ── */
    .card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-left: 4px solid transparent;
        border-radius: 10px;
        margin-bottom: 0.75rem;
        box-shadow: 0 1px 3px rgba(0,0,0,.06);
        transition: box-shadow .15s;
        overflow: hidden;
    }
    .card:hover { box-shadow: 0 4px 12px rgba(0,0,0,.1); }
    .card.highlighted { border-left-color: #f59e0b; }

    /* ── Card header (always visible, clickable) ── */
    .card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.25rem;
        cursor: pointer;
        user-select: none;
        gap: 1rem;
    }
    .card-header::-webkit-details-marker { display: none; }

    .header-left { display: flex; flex-direction: column; gap: 0.2rem; min-width: 0; }

    .match-title {
        font-size: 1.05rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
    }
    .vs { color: #94a3b8; font-weight: 400; font-size: 0.9rem; }

    .match-meta {
        font-size: 0.82rem;
        color: #64748b;
    }

    .header-badges {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        flex-shrink: 0;
    }

    /* ── Badges ── */
    .pill {
        display: inline-block;
        padding: 0.2rem 0.55rem;
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: .02em;
        white-space: nowrap;
    }
    .pill-tomorrow  { background: #fef3c7; color: #92400e; border: 1px solid #f59e0b; }
    .pill-home      { background: #dbeafe; color: #1d4ed8; }
    .pill-away      { background: #ede9fe; color: #6d28d9; }
    .pill-no-fix    { background: #f1f5f9; color: #94a3b8; }
    .pill-over25    { background: #d1fae5; color: #065f46; border: 1px solid #6ee7b7; }
    .pill-home-win  { background: #fef9c3; color: #854d0e; border: 1px solid #fbbf24; }

    /* ── Form badges ── */
    .badge {
        display: inline-block;
        width: 1.6rem;
        height: 1.6rem;
        line-height: 1.6rem;
        text-align: center;
        border-radius: 5px;
        font-size: 0.78rem;
        font-weight: 700;
        margin-right: 2px;
    }
    .badge-W { background: #d1fae5; color: #065f46; }
    .badge-D { background: #f1f5f9; color: #374151; }
    .badge-L { background: #fee2e2; color: #991b1b; }

    /* ── Card body ── */
    .card-body {
        padding: 0 1.25rem 1.25rem;
        border-top: 1px solid #f1f5f9;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.25rem 2rem;
    }

    .stat-column { display: flex; flex-direction: column; gap: 0.9rem; padding-top: 1rem; }

    .column-title {
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
        color: #94a3b8;
        margin-bottom: 0.1rem;
    }

    .stat-block { display: flex; flex-direction: column; gap: 0.25rem; }
    .stat-label { font-size: 0.78rem; color: #64748b; }
    .stat-value { display: flex; align-items: center; gap: 0.15rem; flex-wrap: wrap; }

    .goals-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        padding: 0.25rem 0.6rem;
        font-size: 0.85rem;
    }
    .goals-num { font-weight: 700; color: #0f172a; }
    .goals-den { color: #94a3b8; font-size: 0.78rem; }

    .no-data { color: #cbd5e1; font-style: italic; font-size: 0.82rem; }

    /* ── Divider between columns ── */
    .card-body .stat-column:first-child {
        border-right: 1px solid #f1f5f9;
        padding-right: 1rem;
    }
    .card-body .stat-column:last-child {
        padding-left: 0.25rem;
    }

    /* ── Responsive ── */
    @media (max-width: 600px) {
        .card-body { grid-template-columns: 1fr; }
        .card-body .stat-column:first-child { border-right: none; border-bottom: 1px solid #f1f5f9; padding-right: 0; padding-bottom: 1rem; }
        .card-body .stat-column:last-child { padding-left: 0; }
    }
</style>
{% endblock %}

{% block body %}
<h1>Tomorrow's Bets</h1>
<a href="{{ path('bets_history') }}">Ver historial de apuestas →</a>

{% if bets is empty %}
    <p class="no-data">No tracked teams found.</p>
{% else %}
    {% for bet in bets %}
    <details class="card{% if bet.highlightedTomorrow %} highlighted{% endif %}">
        <summary class="card-header">
            <div class="header-left">
                <div class="match-title">
                    {% if bet.nextFixtureDate %}
                        {% if bet.isHome %}
                            {{ bet.teamName }}
                            <span class="vs">vs</span>
                            {{ bet.nextFixtureOpponentName ?? 'TBD' }}
                        {% else %}
                            {{ bet.nextFixtureOpponentName ?? 'TBD' }}
                            <span class="vs">vs</span>
                            {{ bet.teamName }}
                        {% endif %}
                    {% else %}
                        {{ bet.teamName }}
                    {% endif %}
                </div>
                <div class="match-meta">
                    {% if bet.nextFixtureDate %}
                        {{ bet.nextFixtureDate }}
                    {% else %}
                        No fixture scheduled
                    {% endif %}
                </div>
            </div>
            <div class="header-badges">
                {% if bet.highlightedTomorrow %}
                    <span class="pill pill-tomorrow">TOMORROW</span>
                {% endif %}
                {% if bet.nextFixtureDate %}
                    <span class="pill {{ bet.isHome ? 'pill-home' : 'pill-away' }}">
                        {{ bet.isHome ? 'Home' : 'Away' }}
                    </span>
                {% else %}
                    <span class="pill pill-no-fix">—</span>
                {% endif %}
                {% if 'over_2_5' in bet.activeBetTypes %}
                    <span class="pill pill-over25">OV 2.5</span>
                {% endif %}
                {% if 'home_win' in bet.activeBetTypes %}
                    <span class="pill pill-home-win">1</span>
                {% endif %}
            </div>
        </summary>

        <div class="card-body">

            {# ── Left column: our team ── #}
            <div class="stat-column">
                <div class="column-title">{{ bet.teamName }}</div>

                <div class="stat-block">
                    <div class="stat-label">Form — last 8 (newest → oldest)</div>
                    <div class="stat-value">
                        {% if bet.formLast8 %}
                            {% for char in bet.formLast8|split('') %}
                                <span class="badge badge-{{ char }}">{{ char }}</span>
                            {% endfor %}
                        {% else %}
                            <span class="no-data">No data</span>
                        {% endif %}
                    </div>
                </div>

                <div class="stat-block">
                    <div class="stat-label">Form {{ bet.isHome ? 'at home' : 'away' }} — last 5</div>
                    <div class="stat-value">
                        {% if bet.formSituational %}
                            {% for char in bet.formSituational|split('') %}
                                <span class="badge badge-{{ char }}">{{ char }}</span>
                            {% endfor %}
                        {% else %}
                            <span class="no-data">No data</span>
                        {% endif %}
                    </div>
                </div>

                <div class="stat-block">
                    <div class="stat-label">{{ bet.isHome ? '+2.5 goals at home' : '+1.5 goals away' }}</div>
                    <div class="stat-value">
                        <span class="goals-chip">
                            <span class="goals-num">{{ bet.teamOverCount }}</span>
                            <span class="goals-den">/ {{ bet.teamMatchesPlayed }}</span>
                        </span>
                    </div>
                </div>
            </div>

            {# ── Right column: opponent ── #}
            <div class="stat-column">
                <div class="column-title">{{ bet.nextFixtureOpponentName ?? 'Rival' }}</div>

                <div class="stat-block">
                    <div class="stat-label">Form {{ bet.isHome ? 'away' : 'at home' }} — last 5</div>
                    <div class="stat-value">
                        {% if bet.opponentFormSituational %}
                            {% for char in bet.opponentFormSituational|split('') %}
                                <span class="badge badge-{{ char }}">{{ char }}</span>
                            {% endfor %}
                        {% else %}
                            <span class="no-data">No data</span>
                        {% endif %}
                    </div>
                </div>

                {% if bet.highlightedTomorrow and bet.opponentMatchesPlayed > 0 %}
                <div class="stat-block">
                    <div class="stat-label">{{ bet.isHome ? '+1.5 goals away' : '+2.5 goals at home' }}</div>
                    <div class="stat-value">
                        <span class="goals-chip">
                            <span class="goals-num">{{ bet.opponentOverCount }}</span>
                            <span class="goals-den">/ {{ bet.opponentMatchesPlayed }}</span>
                        </span>
                    </div>
                </div>
                {% endif %}
            </div>

        </div>
    </details>
    {% endfor %}
{% endif %}
{% endblock %}
