{% extends 'base.html.twig' %}

{% block title %}Bet History{% endblock %}

{% block stylesheets %}
<style>
    *, *::before, *::after { box-sizing: border-box; }

    body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        max-width: 1000px;
        margin: 2rem auto;
        padding: 0 1.25rem;
        background: #f8fafc;
        color: #1e293b;
    }

    h1 { font-size: 1.5rem; font-weight: 700; margin-bottom: 1.5rem; color: #0f172a; }
    h2 { font-size: 1.1rem; font-weight: 700; margin: 2rem 0 0.75rem; color: #0f172a; }

    a { color: #3b82f6; text-decoration: none; font-size: 0.85rem; }
    a:hover { text-decoration: underline; }

    table {
        width: 100%;
        border-collapse: collapse;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 1px 3px rgba(0,0,0,.06);
        margin-bottom: 1.5rem;
    }

    th {
        background: #f8fafc;
        padding: 0.6rem 1rem;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
        color: #64748b;
        text-align: left;
        border-bottom: 1px solid #e2e8f0;
    }

    td {
        padding: 0.65rem 1rem;
        font-size: 0.85rem;
        border-bottom: 1px solid #f1f5f9;
        vertical-align: middle;
    }

    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #f8fafc; }

    .badge-status {
        display: inline-block;
        padding: 0.2rem 0.55rem;
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 700;
    }
    .status-won     { background: #d1fae5; color: #065f46; }
    .status-lost    { background: #fee2e2; color: #991b1b; }
    .status-pending { background: #f1f5f9; color: #64748b; }

    .badge-type {
        display: inline-block;
        padding: 0.2rem 0.55rem;
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 700;
        background: #ede9fe;
        color: #6d28d9;
    }

    .win-rate {
        font-weight: 700;
        color: #065f46;
    }

    .no-data { color: #94a3b8; font-style: italic; font-size: 0.85rem; }

    .summary-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 0.75rem;
        margin-bottom: 1.5rem;
    }

    .summary-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 1rem 1.25rem;
        box-shadow: 0 1px 3px rgba(0,0,0,.06);
    }

    .summary-label { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: #94a3b8; }
    .summary-value { font-size: 1.5rem; font-weight: 700; color: #0f172a; margin-top: 0.2rem; }
</style>
{% endblock %}

{% block body %}
<h1>Bet History</h1>
<a href="{{ path('tomorrow_bets') }}">← Back to Tomorrow's Bets</a>

{% set total   = bets|length %}
{% set won     = bets|filter(b => b.status == 'won')|length %}
{% set lost    = bets|filter(b => b.status == 'lost')|length %}
{% set pending = bets|filter(b => b.status == 'pending')|length %}
{% set settled = won + lost %}

<h2>Summary</h2>
<div class="summary-grid">
    <div class="summary-card">
        <div class="summary-label">Total bets</div>
        <div class="summary-value">{{ total }}</div>
    </div>
    <div class="summary-card">
        <div class="summary-label">Won</div>
        <div class="summary-value" style="color:#065f46">{{ won }}</div>
    </div>
    <div class="summary-card">
        <div class="summary-label">Lost</div>
        <div class="summary-value" style="color:#991b1b">{{ lost }}</div>
    </div>
    <div class="summary-card">
        <div class="summary-label">Pending</div>
        <div class="summary-value" style="color:#64748b">{{ pending }}</div>
    </div>
    <div class="summary-card">
        <div class="summary-label">Win rate</div>
        <div class="summary-value">{{ settled > 0 ? ((won / settled * 100)|round(1)) ~ '%' : '—' }}</div>
    </div>
</div>

{% if stats is not empty %}
<h2>Stats by team &amp; type</h2>
<table>
    <thead>
        <tr>
            <th>Team</th>
            <th>Type</th>
            <th>Season</th>
            <th>Bet</th>
            <th>Won</th>
            <th>Lost</th>
            <th>Win %</th>
        </tr>
    </thead>
    <tbody>
        {% for s in stats %}
        <tr>
            <td>{{ s.team.name }}</td>
            <td><span class="badge-type">{{ s.betType|replace({'_': ' '})|upper }}</span></td>
            <td>{{ s.season }}</td>
            <td>{{ s.timesBet }}</td>
            <td>{{ s.timesWon }}</td>
            <td>{{ s.timesLost }}</td>
            <td class="win-rate">{{ s.winRate }}%</td>
        </tr>
        {% endfor %}
    </tbody>
</table>
{% endif %}

<h2>All bets</h2>
{% if bets is empty %}
    <p class="no-data">No bets recorded yet.</p>
{% else %}
<table>
    <thead>
        <tr>
            <th>Date</th>
            <th>Team</th>
            <th>Opponent</th>
            <th>Type</th>
            <th>Season</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        {% for bet in bets %}
        <tr>
            <td>{{ bet.fixtureDate|date('Y-m-d H:i') }}</td>
            <td>{{ bet.team.name }}</td>
            <td>{{ bet.opponentName }}</td>
            <td><span class="badge-type">{{ bet.betType|replace({'_': ' '})|upper }}</span></td>
            <td>{{ bet.season }}</td>
            <td>
                <span class="badge-status status-{{ bet.status }}">
                    {{ bet.status|upper }}
                </span>
            </td>
        </tr>
        {% endfor %}
    </tbody>
</table>
{% endif %}
{% endblock %}
